        "params": [":FTP_START_DATE", ":FTP_END_DATE", ":REFUND_START_DATE", ":REFUND_END_DATE"]
    },
    "2. Бэкапы (BEFORE)": {
        "query": "select tt.column_value as error_desc \nfrom TABLE(UAT_TESTUSER.FTPREFUND_TEST.CHK_TABLES_EMPTY('BEFORE',:FTP_START_DATE,:FTP_END_DATE,:REFUND_START_DATE,:REFUND_END_DATE)) TT;",
        "params": [":FTP_START_DATE", ":FTP_END_DATE", ":REFUND_START_DATE", ":REFUND_END_DATE"]
    },
    "3. Бэкапы (SOURCE)": {
        "query": "select tt.column_value as error_desc \nfrom TABLE(UAT_TESTUSER.FTPREFUND_TEST.CHK_TABLES_EMPTY('',:FTP_START_DATE,:FTP_END_DATE,:REFUND_START_DATE,:REFUND_END_DATE)) TT;",
        "params": [":FTP_START_DATE", ":FTP_END_DATE", ":REFUND_START_DATE", ":REFUND_END_DATE"]
    },
    "4. Сходимость в 0 сумм компенсаций": {
        "query": "select\nround(sum(case when ACCOUNTKIND_UK=1 then REFUND_RUR_AMT else -REFUND_RUR_AMT end),4) RUR,\nround(sum(case when ACCOUNTKIND_UK=1 then REFUND_USD_AMT else -REFUND_USD_AMT end),4) USD,\nround(sum(case when ACCOUNTKIND_UK=1 then REFUND_CUR_AMT else -REFUND_CUR_AMT end),4) CUR\nfrom DWH4DM.IFRSREFUND_SAGG a\nwhere value_day = '{value_day}' and ADJREPORTTYPE_UK=2 and deleted_flag = 'N'",
        "params": ["value_day"]
    },
    "5. Проверка падения сумм по алгоритмам": {
        "query": "select 'Pre', A.VALUE_DAY, GL2ACCOUNT_NCODE, SOURCE_UK, ACCOUNTKIND_UK, FTPALGORITHM_UK, ACCOUNTCLAUSE_NUMBER, avg(A.FTP_AVG), sum (REFUND_USD_AMT), sum (REFUND_CUR_AMT), sum (REFUND_RUR_AMT), count(*) \nfrom DWH4DM.IFRSREFUND_SAGG a \nwhere A.VALUE_DAY = '{value_day}' and A.ADJREPORTTYPE_UK = 2 and a.deleted_flag = 'N' \ngroup by A.VALUE_DAY, SOURCE_UK, ACCOUNTKIND_UK, ACCOUNTCLAUSE_NUMBER, GL2ACCOUNT_NCODE, FTPALGORITHM_UK\nunion \nselect 'PROD', A.VALUE_DAY, GL2ACCOUNT_NCODE, SOURCE_UK, ACCOUNTKIND_UK, FTPALGORITHM_UK, ACCOUNTCLAUSE_NUMBER, avg(A.FTP_AVG), sum (REFUND_USD_AMT), sum (REFUND_CUR_AMT), sum (REFUND_RUR_AMT), count(*) \nfrom DWH4DM.IFRSREFUND_SAGG@DWSTPROD_DMFR a \nwhere A.VALUE_DAY = '{value_day}' and a.deleted_flag = 'N' and A.ADJREPORTTYPE_UK = 2 \ngroup by A.VALUE_DAY, SOURCE_UK, ACCOUNTKIND_UK, ACCOUNTCLAUSE_NUMBER, GL2ACCOUNT_NCODE, FTPALGORITHM_UK",
        "params": ["value_day"]
    },
    "6. Процент заполнения FTP_SSTAT": {
        "query": "WITH IS_NULL AS (SELECT 1 AS CNT, CASE WHEN value_day IS NULL THEN 1 ELSE 0 END AS value_day FROM dwh4dm.FTP_SSTAT) SELECT CASE WHEN value_day = 0 THEN 100 ELSE 100-value_day/(CNT/100) END FROM IS_NULL;",
        "params": []
    },
    "7. Проверка аллокаций": {
