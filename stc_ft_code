        "params": ["start_date", "end_date"]
    },
    "10. Сверка СТЦ с эталоном": {
        "query": "WITH ET AS (SELECT * FROM DWH4DM.FTP_SSTAT_BCKP_20230331 WHERE DELETED_FLAG = 'N' AND VALUE_DAY BETWEEN TO_DATE('{start_date}','YYYYMMDD') AND TO_DATE('{end_date}','YYYYMMDD'))\n, FACT AS (SELECT * FROM DWH4DM.FTP_SSTAT WHERE DELETED_FLAG = 'N' AND VALUE_DAY BETWEEN TO_DATE('{start_date}','YYYYMMDD') AND TO_DATE('{end_date}','YYYYMMDD'))\nSELECT nvl(ET.VALUE_DAY, FACT.VALUE_DAY) FROM ET FULL JOIN FACT ON ET.ACCOUNT_UK = FACT.ACCOUNT_UK;",
        "params": ["start_date", "end_date"]
    },
    "11. Проверка компонент СТЦ": {
        "query": "select * from dwh4dm.ftpcompvalues_shist \nwhere effective_from <= '{ftp_end_date}' and effective_to > '{ftp_start_date}' and abs(VALUE_RATE) > 40;",
        "params": ["ftp_start_date", "ftp_end_date"]
    }
}

class AutoTestGeneratorTk:
    def __init__(self, root):
        self.root = root
        self.root.title("Генератор Тестов STC (Stand-alone)")
        
        # --- Автоматический расчет размера окна без жестких строк ---
        screen_width = self.root.winfo_screenwidth()
        screen_height = self.root.winfo_screenheight()
        # Берем 80% от ширины и высоты экрана пользователя
        width = int(screen_width * 0.8)
        height = int(screen_height * 0.8)
        
        self.root.geometry(f"{width}x{height}")
        # ------------------------------------------------------------
        
        # Главные вкладки
        self.main_tabs = ttk.Notebook(root)
        self.main_tabs.pack(fill="both", expand=True)
        
        self.init_generator_tab()
        self.init_git_tab()

    def init_generator_tab(self):
        tab = ttk.Frame(self.main_tabs)
        self.main_tabs.add(tab, text="Генератор проверок")
        
        paned = ttk.Panedwindow(tab, orient=tk.HORIZONTAL)
        paned.pack(fill="both", expand=True, padx=5, pady=5)
        
        left_frame = ttk.Frame(paned, width=450)
        right_frame = ttk.Frame(paned)
        paned.add(left_frame, weight=2)
        paned.add(right_frame, weight=3)
        
        lbl_frame_cb = ttk.LabelFrame(left_frame, text="Выбор шаблонов")
        lbl_frame_cb.pack(fill="x", padx=5, pady=5)
        
        btn_layout = ttk.Frame(lbl_frame_cb)
        btn_layout.pack(fill="x", padx=5, pady=2)
        ttk.Button(btn_layout, text="Выбрать все", command=self.select_all).pack(side="left", padx=2)
        ttk.Button(btn_layout, text="Снять все", command=self.deselect_all).pack(side="left", padx=2)
        
        self.checkbox_vars = {}
        for name in SQL_TEMPLATES.keys():
            var = tk.BooleanVar()
            cb = ttk.Checkbutton(lbl_frame_cb, text=name, variable=var, command=self.refresh_parameters)
            cb.pack(anchor="w", padx=5, pady=1)
            self.checkbox_vars[name] = var

        self.lbl_frame_params = ttk.LabelFrame(left_frame, text="Обязательные параметры")
        self.lbl_frame_params.pack(fill="x", padx=5, pady=5)
        self.param_fields_frame = ttk.Frame(self.lbl_frame_params)
        self.param_fields_frame.pack(fill="x", padx=5, pady=5)
        self.param_entries = {}

        lbl_frame_extra = ttk.LabelFrame(left_frame, text="Дополнительные условия (Добавятся в WHERE)")
        lbl_frame_extra.pack(fill="x", padx=5, pady=5)
        self.extra_entry = ttk.Entry(lbl_frame_extra)
        self.extra_entry.pack(fill="x", padx=5, pady=5)
        self.extra_entry.insert(0, "")
        
        ttk.Button(left_frame, text="Сгенерировать предпросмотр", command=self.generate_preview).pack(fill="x", padx=5, pady=5)
        ttk.Button(left_frame, text="Сохранить выбранные скрипты в папку", command=self.save_to_folder).pack(fill="x", padx=5, pady=2)
        
        ttk.Label(right_frame, text="Редактирование и предпросмотр готовых скриптов:", font=("Arial", 10, "bold")).pack(anchor="w", pady=2)
        self.preview_notebook = ttk.Notebook(right_frame)
        self.preview_notebook.pack(fill="both", expand=True)
        self.preview_texts = {}

    def init_git_tab(self):
        tab = ttk.Frame(self.main_tabs)
        self.main_tabs.add(tab, text="Git Интеграция")
        
        git_frame = ttk.LabelFrame(tab, text="Пуш изменений в Git репозиторий")
        git_frame.pack(fill="both", expand=True, padx=10, pady=10)
        
        ttk.Label(git_frame, text="Путь к локальной папке проекта:").pack(anchor="w", padx=10, pady=(10, 2))
        folder_row = ttk.Frame(git_frame)
        folder_row.pack(fill="x", padx=10, pady=2)
        self.git_dir_entry = ttk.Entry(folder_row)
        self.git_dir_entry.pack(side="left", fill="x", expand=True, padx=(0, 5))
        ttk.Button(folder_row, text="Обзор...", command=self.browse_git_dir).pack(side="right")
        
        ttk.Label(git_frame, text="Номер задачи для создания ветки (например, 74221):").pack(anchor="w", padx=10, pady=(10, 2))
        self.git_branch_entry = ttk.Entry(git_frame)
        self.git_branch_entry.pack(fill="x", padx=10, pady=2)
        
        ttk.Label(git_frame, text="Удаленный репозиторий (stc_ft.git):").pack(anchor="w", padx=10, pady=(10, 2))
        repo_url = ttk.Entry(git_frame)
        repo_url.insert(0, "https://git.moscow.alfaintra.net/scm/stc_ft/stc_ft.git")
        repo_url.config(state="readonly")
        repo_url.pack(fill="x", padx=10, pady=2)
        
        btn_push = ttk.Button(git_frame, text="Создать ветку, Сделать коммит и Пушнуть", command=self.git_push_workflow)
        btn_push.pack(fill="x", padx=10, pady=20)

    def select_all(self):
        for var in self.checkbox_vars.values():
            var.set(True)
        self.refresh_parameters()

    def deselect_all(self):
        for var in self.checkbox_vars.values():
            var.set(False)
        self.refresh_parameters()

    def refresh_parameters(self):
        for widget in self.param_fields_frame.winfo_children():
            widget.destroy()
            
        needed_params = set()
        for name, var in self.checkbox_vars.items():
            if var.get():
                needed_params.update(SQL_TEMPLATES[name]["params"])
                
        self.param_entries = {}
        for param in sorted(needed_params):
            row = ttk.Frame(self.param_fields_frame)
            row.pack(fill="x", pady=2)
            lbl = ttk.Label(row, text=f"{param}:", width=20, anchor="w")
            lbl.pack(side="left")
            ent = ttk.Entry(row)
            ent.pack(side="left", fill="x", expand=True)
            self.param_entries[param] = ent

    def generate_preview(self):
        for tab in self.preview_notebook.tabs():
            self.preview_notebook.forget(tab)
        self.preview_texts.clear()
        
        extra = self.extra_entry.text().strip()
        
        for name, var in self.checkbox_vars.items():
            if var.get():
                raw_query = SQL_TEMPLATES[name]["query"]
                params = SQL_TEMPLATES[name]["params"]
                
                formatted_query = raw_query
                for p in params:
                    val = self.param_entries[p].get().strip()
                    if not val:
                        val = f"[{p}]"
                    
                    if p.startswith(":"):
                        formatted_query = formatted_query.replace(p, f"'{val}'")
                    else:
                        formatted_query = formatted_query.replace(f"{{{p}}}", val)
                        
                if extra:
                    if "group by" in formatted_query.lower():
                        parts = re.split(r'(group by)', formatted_query, flags=re.IGNORECASE)
                        parts[0] += f"\n {extra} \n"
                        formatted_query = "".join(parts)
                    elif "union" in formatted_query.lower():
                        formatted_query += f"\n\n-- Внимание: UNION! Проверьте WHERE для каждой части:\n-- {extra}"
                    else:
                        formatted_query += f"\n{extra}"
                        
                tab_inner = ttk.Frame(self.preview_notebook)
                self.preview_notebook.add(tab_inner, text=name)
                
                txt = tk.Text(tab_inner, wrap="word", font=("Consolas", 10))
                txt.insert("1.0", formatted_query)
                txt.pack(fill="both", expand=True, padx=5, pady=5)
                
                self.preview_texts[name] = txt

    def save_to_folder(self):
        if not self.preview_texts:
            messagebox.showwarning("Ошибка", "Сначала нажмите 'Сгенерировать предпросмотр'!")
            return
            
        folder = filedialog.askdirectory(title="Выберите папку для выгрузки SQL-файлов")
        if not folder:
            return
            
        try:
            for name, txt_widget in self.preview_texts.items():
                clean_name = "".join([c for c in name if c.isalnum() or c==' ']).strip().replace(' ', '_').lower()
                file_path = os.path.join(folder, f"{clean_name}.sql")
                content = txt_widget.get("1.0", tk.END).strip()
                
                with open(file_path, "w", encoding="utf-8") as f:
                    f.write(content)
                    
            messagebox.showinfo("Успех", f"Успешно сохранено файлов: {len(self.preview_texts)}")
        except Exception as e:
            messagebox.showerror("Ошибка", str(e))

    def browse_git_dir(self):
        folder = filedialog.askdirectory(title="Выберите папку репозитория")
        if folder:
            self.git_dir_entry.delete(0, tk.END)
            self.git_dir_entry.insert(0, folder)

    def run_git_cmd(self, working_dir, args):
        result = subprocess.run(
            ["git"] + args,
            cwd=working_dir,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            creationflags=0x08000000 if os.name == 'nt' else 0
        )
        if result.returncode != 0:
            raise Exception(result.stderr if result.stderr else result.stdout)
        return result.stdout

    def git_push_workflow(self):
        path = self.git_dir_entry.get().strip()
        task_num = self.git_branch_entry.get().strip()
        
        if not path or not os.path.exists(path):
            messagebox.showwarning("Ошибка", "Укажите корректный путь к папке проекта!")
            return
        if not task_num:
            messagebox.showwarning("Ошибка", "Поле номера задачи пустое!")
            return
            
        branch_name = task_num
        
        try:
            if not os.path.exists(os.path.join(path, ".git")):
                self.run_git_cmd(path, ["init"])
                self.run_git_cmd(path, ["remote", "add", "origin", "https://git.moscow.alfaintra.net/scm/stc_ft/stc_ft.git"])
            
            try:
                self.run_git_cmd(path, ["remote", "set-url", "origin", "https://git.moscow.alfaintra.net/scm/stc_ft/stc_ft.git"])
            except:
                try:
                    self.run_git_cmd(path, ["remote", "add", "origin", "https://git.moscow.alfaintra.net/scm/stc_ft/stc_ft.git"])
                except:
                    pass

            self.run_git_cmd(path, ["add", "-A"])
            self.run_git_cmd(path, ["checkout", "-B", branch_name])
            
            try:
                self.run_git_cmd(path, ["commit", "-m", f"Автогенерация тестов по задаче {task_num}"])
            except Exception as e:
                if "nothing to commit" in str(e).lower() or "nothing added to commit" in str(e).lower():
                    pass
                else:
                    raise e
            
            self.run_git_cmd(path, ["push", "origin", f"{branch_name}:{branch_name}", "--force"])
            messagebox.showinfo("Git Успех", f"Ветка '{branch_name}' успешно создана и отправлена в репозиторий!")
            
        except Exception as e:
            messagebox.showerror("Git Ошибка", f"Не удалось завершить операцию Git:\n{str(e)}")

if __name__ == "__main__":
    root = tk.Tk()
    app = AutoTestGeneratorTk(root)
    root.mainloop()
