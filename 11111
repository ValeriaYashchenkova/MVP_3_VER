pipeline {
    agent {
        kubernetes {
            inheritFrom 'python'
            defaultContainer 'python-builder'
        }
    }

    // ==================== ПАРАМЕТРЫ ЗАПУСКА ====================
    parameters {
        string(
            name: 'BRANCH_NAME',
            defaultValue: 'master',
            description: 'Ветка для проверки'
        )
        
        string(
            name: 'SUITE',
            defaultValue: 'all',
            description: '''Какой suite запускать?
Введите одно из значений:
- all          (все тесты)
- suite3       
- suite4 
- ...
Можно указать несколько через запятую: suite3,suite4'''
        )

        string(
            name: 'TEST_TARGET',
            defaultValue: 'schemas/', 
            description: '''Путь к тестам для запуска.
Оставьте в поле schemas/ для проверки вообще всех таблиц.
Для конкретной схемы: schemas/ИМЯ_СХЕМЫ/ (например: schemas/DMALM/)
Для конкретной таблицы: schemas/ИМЯ_СХЕМЫ/ИМЯ_ТАБЛИЦЫ/ (например: schemas/DMALM/LOANS_FL_SHIST/)'''
        )
    }

    environment {
        ALLURE_RESULTS = "${WORKSPACE}/allure-results"
    }

    stages {
        stage('Setup Python & Install dependencies') {
            steps {
                sh """
                    python3.7 -m venv venv || true
                    . venv/bin/activate
                    pip3.7 install --upgrade pip -i https://binary.alfabank.ru/artifactory/api/pypi/pipy-virtual/simple
                    pip3.7 install oracledb gitpython pandas requests tomli pytest allure-pytest -i https://binary.alfabank.ru/artifactory/api/pypi/pipy-virtual/simple
                """
            }
        }
       stage('Run Tests') {
            steps {
                script {
                    def suiteInput = params.SUITE.trim().toLowerCase()
                    def pytestMarker = ""

                    if (suiteInput == 'all' || suiteInput == '') {
                        pytestMarker = ""                    // запускаем все тесты
                    } 
                    else if (suiteInput.contains(',')) {
                        // поддержка нескольких suite через запятую
                        def markers = suiteInput.split(',').collect { it.trim() }.join(" or ")
                        pytestMarker = "-m \"${markers}\""
                    } 
                    else {
                        pytestMarker = "-m ${suiteInput}"    // один suite
                    }

                    echo "=== Запуск тестов. Путь: ${params.TEST_TARGET} | SUITE: ${params.SUITE} ==="

                    withAllureUpload(
                        credentialsId: 'allure-token',
                        name: "Data Quality #${BUILD_NUMBER} | ${params.BRANCH_NAME} | TARGET: ${params.TEST_TARGET ?: 'ALL'} | SUITE: ${params.SUITE}",
                        projectId: '643',
                        results: [[path: "${ALLURE_RESULTS}"]],
                        serverId: 'testops',
                        tags: "${params.BRANCH_NAME},sql-checks,${params.SUITE}",
                        indexExistingFiles: true
                    ) {
                        sh """
                            . venv/bin/activate
                            rm -rf ${ALLURE_RESULTS}
                            mkdir -p ${ALLURE_RESULTS}
                            
                            export DB_USER="\${DB_USER}"
                            export DB_PASS="\${DB_PASS}"
                            
                            pytest ${params.TEST_TARGET} ${pytestMarker} \
                                --alluredir=${ALLURE_RESULTS} \
                                -q \
                                --tb=short
                        """
                    }
                }
            }
        }
    }
    post {
        always {
            archiveArtifacts artifacts: 'allure-results/**', allowEmptyArchive: true
            cleanWs()
        }
    }
}
