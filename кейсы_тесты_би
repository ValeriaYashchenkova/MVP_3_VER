-- -----------------------------------------------------------------------------------
-- DQ-01: Инверсия дат SCD2 (Критический системный баг, который мы ловили ранее)
-- Ожидание: 0 строк. Если > 0 — алгоритм открытия/закрытия версий сломан.
-- -----------------------------------------------------------------------------------
SELECT ACCOUNT_UK, EFFECTIVE_FROM, EFFECTIVE_TO 
FROM DWH4DM.FTPRATE_TEMP_SSTAT 
WHERE DELETED_FLAG <> 'Y' 
  AND EFFECTIVE_TO <= EFFECTIVE_FROM;

-- -----------------------------------------------------------------------------------
-- DQ-02: Дубляж активных версий (Декартово произведение в ETL)
-- Ожидание: 0 строк. У одного счета в один момент времени может быть только одна открытая версия.
-- -----------------------------------------------------------------------------------
SELECT ACCOUNT_UK, COUNT(*) AS ACTIVE_VERSIONS
FROM DWH4DM.FTPRATE_TEMP_SSTAT 
WHERE DELETED_FLAG <> 'Y' 
  AND EFFECTIVE_TO = TO_DATE('59991231', 'YYYYMMDD') 
GROUP BY ACCOUNT_UK 
HAVING COUNT(*) > 1;

-- -----------------------------------------------------------------------------------
-- DQ-03: Разрывы в историчности (SCD2 Gaps)
-- Ожидание: 0 строк. Предыдущая версия должна закрываться точно в день открытия новой.
-- -----------------------------------------------------------------------------------
SELECT ACCOUNT_UK, PREV_EFFECTIVE_TO, NEXT_EFFECTIVE_FROM
FROM (
    SELECT 
        ACCOUNT_UK, 
        EFFECTIVE_TO AS PREV_EFFECTIVE_TO, 
        LEAD(EFFECTIVE_FROM) OVER (PARTITION BY ACCOUNT_UK ORDER BY EFFECTIVE_FROM) AS NEXT_EFFECTIVE_FROM
    FROM DWH4DM.FTPRATE_TEMP_SSTAT 
    WHERE DELETED_FLAG <> 'Y'
)
WHERE NEXT_EFFECTIVE_FROM IS NOT NULL 
  AND NEXT_EFFECTIVE_FROM > PREV_EFFECTIVE_TO; 
  -- В зависимости от архитектуры (Day/Day+1) условие может быть: NEXT_EFFECTIVE_FROM <> PREV_EFFECTIVE_TO

-- -----------------------------------------------------------------------------------
-- DQ-04: Сироты (Orphans) — Баланс есть, а ставки СТЦ нет
-- Ожидание: 0 строк. Проверка фоллбэк-алгоритма. Если ставка не посчиталась, сделка "зависла".
-- -----------------------------------------------------------------------------------
SELECT b.ACCOUNT_UK, b.VALUE_DAY
FROM DWH4DM.ACCTDEALBALANCE_FTP_SSTAT b
LEFT JOIN DWH4DM.FTPRATE_TEMP_SSTAT r 
  ON b.ACCOUNT_UK = r.ACCOUNT_UK 
 AND b.VALUE_DAY = r.VALUE_DAY
WHERE b.VALUE_DAY = TO_DATE('20260528', 'YYYYMMDD') -- Проверка за вчерашний опер.день
  AND b.DELETED_FLAG <> 'Y'
  AND r.ACCOUNT_UK IS NULL;

-- -----------------------------------------------------------------------------------
-- DQ-05: Экстремальные / Отрицательные теноры (Ошибки в АБС)
-- Ожидание: 0 строк. Ищем опечатки фронт-офиса, где конец кредита наступает до его начала.
-- -----------------------------------------------------------------------------------
SELECT ACCOUNT_UK, START_DATE, END_PLAN_DATE, (END_PLAN_DATE - START_DATE) AS TENOR_DAYS
FROM DWH4DM.ACCTDEALBALANCE_FTP_SSTAT
WHERE DELETED_FLAG <> 'Y' 
  AND END_PLAN_DATE <= START_DATE;
