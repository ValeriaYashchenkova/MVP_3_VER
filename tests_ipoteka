import pytest
import oracledb
import os
import allure

@allure.feature("Pipeline Smoke Tests")
@allure.story("Database Connectivity")
def test_db_connection():
    # Получаем данные из переменных окружения Jenkins
    db_user = os.getenv("DB_USER")
    db_pass = os.getenv("DB_PASS")
    dsn = "EXA3-SCAN:1521/FDTST2"

    with allure.step(f"Попытка подключения к базе данных {dsn}"):
        try:
            connection = oracledb.connect(
                user=db_user,
                password=db_pass,
                dsn=dsn
            )
            
            # Простейший запрос для проверки работоспособности
            with connection.cursor() as cursor:
                cursor.execute("SELECT 1 FROM DUAL")
                result = cursor.fetchone()
                assert result[0] == 1, "Запрос к БД вернул некорректный результат"
            
            connection.close()
            allure.attach("Подключение успешно", name="Status", attachment_type=allure.attachment_type.TEXT)
            
        except oracledb.Error as e:
            allure.attach(str(e), name="Error Details", attachment_type=allure.attachment_type.TEXT)
            pytest.fail(f"Ошибка подключения к БД: {e}")
