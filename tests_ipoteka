WITH target_data AS (
    -- Данные из твоей витрины
    SELECT deal_uk, ftp_rate as actual_ftp, effective_from as load_date
    FROM DWH4DM.MORTGAGE_FTP_SHIST
    WHERE deal_uk = 5238061313 -- ID твоей сделки
      AND effective_to = TO_DATE('31.12.5999', 'dd.mm.yyyy')
),
source_data AS (
    -- Эталон: ищем единственную верную ставку на момент начала сделки
    -- Используем фильтр по RATETYPE_UK = 1 и берем MAX(effective_from)
    SELECT deal_uk, int_rate as expected_ftp
    FROM (
        SELECT deal_uk, int_rate,
               ROW_NUMBER() OVER (PARTITION BY deal_uk ORDER BY effective_from DESC) as rn
        FROM DWH4DM.DEALRATEINFO_SHIST
        WHERE deal_uk = 5238061313
          AND ratetype_uk = 1
          -- Важно: ставка должна быть актуальна на момент СТАРТА сделки
          AND effective_from <= (SELECT start_date FROM DWH4DM.DEAL_EDIM WHERE uk = 5238061313)
    )
    WHERE rn = 1
)
SELECT 
    t.deal_uk,
    t.actual_ftp,
    s.expected_ftp,
    CASE 
        WHEN ABS(t.actual_ftp - s.expected_ftp) > 0.001 THEN 'ДЕФЕКТ: Ставка неверная'
        ELSE 'OK'
    END as status
FROM target_data t
JOIN source_data s ON t.deal_uk = s.deal_uk;
