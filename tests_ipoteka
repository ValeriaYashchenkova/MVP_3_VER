WITH target_data AS (
    SELECT deal_uk, ftp_rate as actual_ftp
    FROM DWH4DM.MORTGAGE_FTP_SHIST
    WHERE deal_uk = 5238061313
      AND effective_to = TO_DATE('31.12.5999', 'dd.mm.yyyy')
),
source_data AS (
    SELECT deal_uk, int_rate as expected_ftp
    FROM (
        SELECT deal_uk, int_rate,
               ROW_NUMBER() OVER (PARTITION BY deal_uk ORDER BY effective_from DESC) as rn
        FROM DWH4DM.DEALRATEINFO_SHIST
        WHERE deal_uk = 5238061313
          AND ratetype_uk = 1
          -- Исправленный подзапрос: берем максимум, чтобы избежать ORA-01427
          AND effective_from <= (SELECT MAX(start_date) FROM DWH4DM.DEAL_EDIM WHERE uk = 5238061313)
    )
    WHERE rn = 1
)
SELECT 
    t.deal_uk,
    t.actual_ftp,
    s.expected_ftp,
    CASE 
        WHEN ABS(NVL(t.actual_ftp, 0) - NVL(s.expected_ftp, 0)) > 0.001 THEN 'ДЕФЕКТ: Ставка неверная'
        ELSE 'OK'
    END as status
FROM target_data t
JOIN source_data s ON t.deal_uk = s.deal_uk;
