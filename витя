WITH SRCx AS (
--13.05.2026 00:00:00.000	100545646	100545646	81956508
SELECT * FROM DMALM.ALMIFRSBALANCE_SSTAT_INCR0
WHERE VALUE_DAY=TO_DATE('13.05.2026','dd.mm.yyyy') 
)
,TGTx AS (
--
SELECT * FROM DMALM.ALMIFRSBALANCE_SSTAT
WHERE VALUE_DAY=TO_DATE('15.04.2026','dd.mm.yyyy') 
)
SELECT 
sum(decode(SRCx.ACCOUNT_UK, TGTx.ACCOUNT_UK, 0, 1)) AS ACCOUNT_UK
,sum(decode(SRCx.DEAL_UK, TGTx.DEAL_UK, 0, 1)) AS DEAL_UK
,sum(decode(SRCx.VALUE_DAY, TGTx.VALUE_DAY, 0, 1)) AS VALUE_DAY
,sum(decode(SRCx.ACCOUNTCLAUSE_BAL_UK, TGTx.ACCOUNTCLAUSE_BAL_UK, 0, 1)) AS ACCOUNTCLAUSE_BAL_UK
,sum(decode(SRCx.ACCOUNTCLAUSE_IFRSBAL_UK, TGTx.ACCOUNTCLAUSE_IFRSBAL_UK, 0, 1)) AS ACCOUNTCLAUSE_IFRSBAL_UK
,sum(decode(SRCx.ACCOUNTGROUP_UK, TGTx.ACCOUNTGROUP_UK, 0, 1)) AS ACCOUNTGROUP_UK
,sum(decode(SRCx.ACCOUNTKIND_UK, TGTx.ACCOUNTKIND_UK, 0, 1)) AS ACCOUNTKIND_UK
,sum(decode(SRCx.ACCOUNT_NUMBER, TGTx.ACCOUNT_NUMBER, 0, 1)) AS ACCOUNT_NUMBER
,sum(decode(SRCx.ADJUSTED_FTP_RATE, TGTx.ADJUSTED_FTP_RATE, 0, 1)) AS ADJUSTED_FTP_RATE
