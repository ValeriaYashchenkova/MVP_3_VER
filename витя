,sum(decode(SRCx.ALMDEALTYPE_RULE_TK, TGTx.ALMDEALTYPE_RULE_TK, 0, 1)) AS ALMDEALTYPE_RULE_TK
,sum(decode(SRCx.BALANCE_CUR_AMT, TGTx.BALANCE_CUR_AMT, 0, 1)) AS BALANCE_CUR_AMT
,sum(decode(SRCx.BALANCEFACTOR, TGTx.BALANCEFACTOR, 0, 1)) AS BALANCEFACTOR
,sum(decode(SRCx.BALANCE_FLAG, TGTx.BALANCE_FLAG, 0, 1)) AS BALANCE_FLAG
,sum(decode(SRCx.BALANCE_RUR_AMT, TGTx.BALANCE_RUR_AMT, 0, 1)) AS BALANCE_RUR_AMT
,sum(decode(SRCx.BALANCE_USD_AMT, TGTx.BALANCE_USD_AMT, 0, 1)) AS BALANCE_USD_AMT
,sum(decode(SRCx.BAL2USD4COMP_DATE, TGTx.BAL2USD4COMP_DATE, 0, 1)) AS BAL2USD4COMP_DATE
,sum(decode(SRCx.CLIENT_AA_UK, TGTx.CLIENT_AA_UK, 0, 1)) AS CLIENT_AA_UK
,sum(decode(SRCx.CLIENT_SUPPLIER_UK, TGTx.CLIENT_SUPPLIER_UK, 0, 1)) AS CLIENT_SUPPLIER_UK
,sum(decode(SRCx.CLIENT_UK, TGTx.CLIENT_UK, 0, 1)) AS CLIENT_UK
,sum(decode(SRCx.CURRENCY_ACCOUNT_UK, TGTx.CURRENCY_ACCOUNT_UK, 0, 1)) AS CURRENCY_ACCOUNT_UK
,sum(decode(SRCx.DEAL_REF, TGTx.DEAL_REF, 0, 1)) AS DEAL_REF
,sum(decode(SRCx.DEALTABLE_UK, TGTx.DEALTABLE_UK, 0, 1)) AS DEALTABLE_UK
,sum(decode(SRCx.DEAL2ACCTTYPE_UK, TGTx.DEAL2ACCTTYPE_UK, 0, 1)) AS DEAL2ACCTTYPE_UK
,sum(decode(SRCx.FORINDEX_RATE, TGTx.FORINDEX_RATE, 0, 1)) AS FORINDEX_RATE
,sum(decode(SRCx.FTPALGORITHM_UK, TGTx.FTPALGORITHM_UK, 0, 1)) AS FTPALGORITHM_UK
,sum(decode(SRCx.FTPFOR_PCT_RATE, TGTx.FTPFOR_PCT_RATE, 0, 1)) AS FTPFOR_PCT_RATE
,sum(decode(SRCx.FTP_RATE, TGTx.FTP_RATE, 0, 1)) AS FTP_RATE
,sum(decode(SRCx.GL2ACCOUNT_NCODE, TGTx.GL2ACCOUNT_NCODE, 0, 1)) AS GL2ACCOUNT_NCODE
,sum(decode(SRCx.GL2ACCOUNT_UK, TGTx.GL2ACCOUNT_UK, 0, 1)) AS GL2ACCOUNT_UK
,sum(decode(SRCx.IFRSBALANCEFACTOR, TGTx.IFRSBALANCEFACTOR, 0, 1)) AS IFRSBALANCEFACTOR
,sum(decode(SRCx.PRINCIPAL_FLAG, TGTx.PRINCIPAL_FLAG, 0, 1)) AS PRINCIPAL_FLAG
,sum(decode(SRCx.PRODUCT_L2_UK, TGTx.PRODUCT_L2_UK, 0, 1)) AS PRODUCT_L2_UK
,sum(decode(SRCx.PRODUCT_L3_UK, TGTx.PRODUCT_L3_UK, 0, 1)) AS PRODUCT_L3_UK
,sum(decode(SRCx.PRODUCT_NCODE, TGTx.PRODUCT_NCODE, 0, 1)) AS PRODUCT_NCODE
,sum(decode(SRCx.PROFITCENTER_UK, TGTx.PROFITCENTER_UK, 0, 1)) AS PROFITCENTER_UK
,sum(decode(SRCx.RATE, TGTx.RATE, 0, 1)) AS RATE
,sum(decode(SRCx.SALESPLACE_BRANCH_UK, TGTx.SALESPLACE_BRANCH_UK, 0, 1)) AS SALESPLACE_BRANCH_UK
,sum(decode(SRCx.SALESPLACE_DEPTACCOUNT_UK, TGTx.SALESPLACE_DEPTACCOUNT_UK, 0, 1)) AS SALESPLACE_DEPTACCOUNT_UK
,sum(decode(SRCx.SECURITYACCTYPE_UK, TGTx.SECURITYACCTYPE_UK, 0, 1)) AS SECURITYACCTYPE_UK
,sum(decode(SRCx.SECURITY_CNT, TGTx.SECURITY_CNT, 0, 1)) AS SECURITY_CNT
,sum(decode(SRCx.SECURITY_UK, TGTx.SECURITY_UK, 0, 1)) AS SECURITY_UK
,sum(decode(SRCx.SRC_XK, TGTx.SRC_XK, 0, 1)) AS SRC_XK
,sum(decode(SRCx.STANDARDFTP_RATE, TGTx.STANDARDFTP_RATE, 0, 1)) AS STANDARDFTP_RATE,sum(decode(SRCx.SUBHLDMEMBER_UK, TGTx.SUBHLDMEMBER_UK, 0, 1)) AS SUBHLDMEMBER_UK
,sum(decode(SRCx.TENOR_FTP_NCODE, TGTx.TENOR_FTP_NCODE, 0, 1)) AS TENOR_FTP_NCODE
,sum(decode(SRCx.TENOR_FTP_UK, TGTx.TENOR_FTP_UK, 0, 1)) AS TENOR_FTP_UK
,sum(decode(SRCx.XK, TGTx.XK, 0, 1)) AS XK
,sum(decode(SRCx.DELETED_FLAG, TGTx.DELETED_FLAG, 0, 1)) AS DELETED_FLAG
,sum(decode(SRCx.AS_OF_DAY, TGTx.AS_OF_DAY, 0, 1)) AS AS_OF_DAY
,sum(decode(SRCx.JOB_INSERT, TGTx.JOB_INSERT, 0, 1)) AS JOB_INSERT
,sum(decode(SRCx.JOB_UPDATE, TGTx.JOB_UPDATE, 0, 1)) AS JOB_UPDATE
,sum(decode(SRCx.INSURED_FLAG, TGTx.INSURED_FLAG, 0, 1)) AS INSURED_FLAG
FROM SRCx JOIN TGTx ON
--ACCOUNT_UK, DEAL_UK, VALUE_DAY, ALMDEALTYPE_NCODE
SRCx.ACCOUNT_UK = TGTx.ACCOUNT_UK
AND SRCx.DEAL_UK = TGTx.DEAL_UK
AND SRCx.VALUE_DAY = TGTx.VALUE_DAY
AND SRCx.ALMDEALTYPE_NCODE = TGTx.ALMDEALTYPE_NCODE
