-- ===================================================================================
-- SQL-СКРИПТЫ АВТОМАТИЗИРОВАННОЙ ПРОВЕРКИ (АУДИТ ТЕСТ-КЕЙСОВ 41 РЕЛИЗА)
-- ===================================================================================

ALTER SESSION SET CURRENT_SCHEMA = DWH4DM;

-- -----------------------------------------------------------------------------------
-- ПРОВЕРКА 1: Контроль фиктивной строки (Кейс 4/6)
-- Ожидается: 0 строк (Пусто).
-- Если запрос что-то вернул — баг. Заглушка искажает финансовый результат (ставка > 0).
-- -----------------------------------------------------------------------------------
SELECT ACCOUNT_UK, FTP_RATE, DESCRIPTION 
FROM FTPRATE_TEMP_SSTAT 
WHERE ACCOUNT_UK = -999 AND FTP_RATE > 0;

-- -----------------------------------------------------------------------------------
-- ПРОВЕРКА 2: Абсолютный приоритет VIP-ставки (Кейс 5)
-- Ожидается: Ровно 1 строка, где FTP_PRIORITY = 1, а ставка FTP_RATE = 0.055 (5.5%).
-- -----------------------------------------------------------------------------------
SELECT ACCOUNT_UK, FTP_PRIORITY, FTP_RATE, DESCRIPTION 
FROM FTPRATE_TEMP_SSTAT 
WHERE ACCOUNT_UK = 41000205;

-- -----------------------------------------------------------------------------------
-- ПРОВЕРКА 3: Сброс ставки с пустым драйвером (Кейс 6)
-- Ожидается: 0 строк.
-- Если вернулась строка — баг. Система применила ручной тариф без драйвера.
-- -----------------------------------------------------------------------------------
SELECT ACCOUNT_UK, FTP_PRIORITY, DESCRIPTION 
FROM FTPRATE_TEMP_SSTAT 
WHERE ACCOUNT_UK = 41000206 AND FTP_PRIORITY = 1;

-- -----------------------------------------------------------------------------------
-- ПРОВЕРКА 4: Точечный казначейский мэтчинг (Кейсы 7 и 9)
-- Ожидается: 1 строка, где FTP_PRIORITY = 2 (уровень заявки), ставка = 0.0641 (6.41%).
-- -----------------------------------------------------------------------------------
SELECT ACCOUNT_UK, FTP_PRIORITY, FTP_RATE 
FROM FTPRATE_TEMP_SSTAT 
WHERE ACCOUNT_UK = 41000307;

-- -----------------------------------------------------------------------------------
-- ПРОВЕРКА 5: Защита от дублей при Cartesian Product (Кейс 11)
-- Ожидается: ROW_CNT должен быть равен 1. 
-- Если > 1 — баг аналитической функции row_number(), дельта размножилась.
-- -----------------------------------------------------------------------------------
SELECT ACCOUNT_UK, COUNT(*) as ROW_CNT 
FROM FTPRATE_TEMP_SSTAT 
WHERE ACCOUNT_UK = 41000515 
GROUP BY ACCOUNT_UK;

-- -----------------------------------------------------------------------------------
-- ПРОВЕРКА 6: Защита от Zero Divide при расчете форварда (Кейс 16)
-- Ожидается: 1 строка. Поле FTPFOR_RATE не должно быть пустым и сессия не должна упасть.
-- -----------------------------------------------------------------------------------
SELECT FUNDINGKEYS_UK, FTPFOR_RATE, FTP_RATE 
FROM FTPRATE_TEMP_SSTAT 
WHERE FUNDINGKEYS_UK = 41066012;

-- -----------------------------------------------------------------------------------
-- ПРОВЕРКА 7: Аудит "Сделки-сироты" / Нарушение ссылочной целостности (Кейсы 37-38)
-- Ожидается: 1 строка. 
-- Если 0 строк — критический баг. Разработчик применил INNER JOIN к DEAL_EDIM.
-- -----------------------------------------------------------------------------------
SELECT ACCOUNT_UK, FTP_RATE, DESCRIPTION 
FROM FTPRATE_TEMP_SSTAT 
WHERE DEAL_UK = 41000937;

-- -----------------------------------------------------------------------------------
-- ПРОВЕРКА 8: Отлов математического отравления (NULL Poisoning) (Кейс 42)
-- Ожидается: 0 строк.
-- Если есть строки — баг. Разработчик забыл обернуть слагаемые в функцию NVL(..., 0).
-- -----------------------------------------------------------------------------------
SELECT ACCOUNT_UK, FTP_RATE 
FROM FTPRATE_TEMP_SSTAT 
WHERE ACCOUNT_UK = 41001042 AND FTP_RATE IS NULL;

-- -----------------------------------------------------------------------------------
-- ПРОВЕРКА 9: Аудит пересечения исторических периодов (SCD2 Overlap) (Кейс 41)
-- Ожидается: 0 строк.
-- Если запрос что-то вернул — баг джойна исторических слоев (задвоение на одну дату).
-- -----------------------------------------------------------------------------------
SELECT ACCOUNT_UK, VALUE_DAY, COUNT(*) as DUPES 
FROM FTPRATE_TEMP_SSTAT 
WHERE ACCOUNT_UK = 41001041 
GROUP BY ACCOUNT_UK, VALUE_DAY 
HAVING COUNT(*) > 1;

-- -----------------------------------------------------------------------------------
-- ПРОВЕРКА 10: Глобальный сканер финансовых аномалий 
-- (Нулевая маржа, отрицательные спреды-опечатки, неразмеченные продукты)
-- Ожидается: Скрипт поймает только заложенные нами негативные кейсы (Кейсы 18, 26).
-- На чистом проде этот запрос должен всегда возвращать 0 строк.
-- -----------------------------------------------------------------------------------
SELECT 
    f.ACCOUNT_UK, 
    f.FTP_RATE as TRANSFER_RATE, 
    f.FTPFOR_RATE as FORWARD_RATE, 
    adb.INTEREST_RATE as CLIENT_RATE,
    f.FTP_PRIORITY,
    f.DESCRIPTION
FROM FTPRATE_TEMP_SSTAT f
LEFT JOIN ACCTDEALBALANCE_FTP_SSTAT adb 
    ON f.ACCOUNT_UK = adb.ACCOUNT_UK AND f.VALUE_DAY = adb.VALUE_DAY
WHERE f.ACCOUNT_UK LIKE '410%' 
AND (
    f.FTPFOR_RATE < -50              -- Опечатки типа -99
    OR f.FTP_RATE = adb.INTEREST_RATE -- Нулевая маржа (СТЦ равен ставке клиента)
    OR f.FTP_PRIORITY IS NULL         -- Сделка не нашла свой алгоритм (выход за GL2)
);
